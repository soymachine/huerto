---
import OrchardApp from '../components/OrchardApp';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Planificador visual de huertos urbanos y familiares. Rotación de cultivos, asociaciones entre plantas y recordatorios de siembra." />
    <title>El Huerto — Planificador de cultivos</title>
    <link rel="manifest" href="/huerto/manifest.json" />
    <meta name="theme-color" content="#3A6020" />
    <link rel="icon" href="/huerto/icon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/huerto/sw.js').catch(() => {});
        });
      }
    </script>
  </head>
  <body>
    <OrchardApp client:load />
  </body>
</html>
